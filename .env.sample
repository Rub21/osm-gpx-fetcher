OSM_URL=https://openstreetmap.204-168-242-139.nip.io

# oauth2 app credentials (register at $OSM_URL/oauth2/applications)
CLIENT_ID=1234
CLIENT_SECRET=1234

# access token returned by osm_generate_token.py (used by upload_gpx.sh)
TOKEN=abc

# upload_gpx.sh
GPX_DIR=data/gpx
VISIBILITY=public

# fetch.py / docker-compose
OUT_DIR=/data
TARGET_COUNT=10000
DELAY=2.0
LIMIT=0
WATCH=1
WATCH_INTERVAL=120
RATE_LIMIT_COOLDOWN=3600
